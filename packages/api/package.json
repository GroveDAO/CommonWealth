{
  "name": "@commonwealth/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "pnpm --filter @commonwealth/sdk build",
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@commonwealth/sdk": "workspace:*",
    "@fastify/cors": "^9.0.1",
    "fastify": "^4.28.1",
    "viem": "^2.10.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "tsup": "^8.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.4.0"
  }
}